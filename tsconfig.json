{
    "compilerOptions": {
        "module": "es2022",
        "moduleResolution": "bundler",
        "target": "ES2023",
        "strict": true,
        "esModuleInterop": true,
        "outDir": "dist",
        "rootDir": "src",
        "sourceMap": true,
        "noEmitOnError": true,
        "paths": {
            "@/*":["./src/*"]
        }
    },
    "tsc-alias": {
        "resolveFullPaths": true,
        "verbose": false
    }
}
